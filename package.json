  "description": "Materia — the Examine.com of the whole body. Explore a layered human body and find evidence-graded, study-cited herbs, supplements, and drugs for any part or condition.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
