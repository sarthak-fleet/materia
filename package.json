    "@fontsource-variable/inter": "^5.2.5",
    "@nanostores/react": "^0.8.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.7",
    "astro": "^5.8.0",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.460.0",
    "nanostores": "^0.11.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.7",
    "three": "^0.171.0"
  },
  "devDependencies": {
