---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const [conditions, remedies, compounds, parts] = await Promise.all([
  getCollection('conditions'),
  getCollection('remedies'),
  getCollection('compounds'),
  getCollection('bodyParts'),
]);

// Build-time search index. Phase 2 adds client-side embeddings on top of this
// deterministic baseline (the model only ranks; it never generates).
const index = [
  ...parts.map((p) => ({ t: p.data.name, s: p.data.summary, u: `/part/${p.id}`, k: 'Body part', a: [] as string[] })),
  ...conditions.map((c) => ({ t: c.data.name, s: c.data.summary, u: `/condition/${c.id}`, k: 'Condition', a: c.data.aliases })),
  ...remedies.map((r) => ({ t: r.data.name, s: r.data.summary, u: `/remedy/${r.id}`, k: 'Remedy', a: r.data.aliases })),
  ...compounds.map((c) => ({ t: c.data.name, s: c.data.summary, u: `/compound/${c.id}`, k: 'Compound', a: c.data.aliases })),
];
---

<BaseLayout title="Search" description="Search conditions, remedies, body parts, and compounds.">
  <section class="container-x py-12">
    <p class="eyebrow mb-3">Search</p>
    <h1 class="text-4xl">Find anything</h1>
    <p class="mt-3 max-w-xl text-muted">
      Search by symptom, remedy, body part, or compound — try “joint pain”, “turmeric”, or “knee”.
    </p>

    <div class="mt-6">
      <input
        id="q"
        type="search"
        autofocus
        placeholder="Search Materia…"
        class="w-full rounded-xl border border-line bg-surface px-4 py-3 text-lg text-ink outline-none placeholder:text-faint focus:border-accent"
        aria-label="Search"
      />
    </div>

    <p id="count" class="mt-4 text-sm text-faint"></p>
    <ul id="results" class="mt-2 divide-y divide-line overflow-hidden rounded-xl border border-line bg-surface"></ul>
  </section>

  <script is:inline type="application/json" id="search-index" set:html={JSON.stringify(index)} />

  <script is:inline>
    (() => {
      const data = JSON.parse(document.getElementById('search-index').textContent);
      const q = document.getElementById('q');
      const results = document.getElementById('results');
      const count = document.getElementById('count');
      const KIND_COLOR = {
        Condition: 'var(--color-grade-b)',
        Remedy: 'var(--color-accent)',
        Compound: 'var(--color-grade-c)',
        'Body part': 'var(--color-grade-d)',
      };

      function render(items, query) {
        results.innerHTML = '';
        if (query && items.length === 0) {
          count.textContent = `No matches for “${query}”.`;
          return;
        }
        count.textContent = query
          ? `${items.length} result${items.length === 1 ? '' : 's'}`
          : `${items.length} entries`;
        for (const it of items.slice(0, 60)) {
          const li = document.createElement('li');
          li.innerHTML = `<a href="${it.u}" class="flex items-center gap-3 p-4 transition-colors hover:bg-[var(--color-accent-soft)]">
            <span class="rounded-md px-2 py-0.5 text-[11px] font-medium text-white shrink-0" style="background:${KIND_COLOR[it.k] || 'var(--color-faint)'}">${it.k}</span>
            <span class="min-w-0">
              <span class="block font-medium text-[var(--color-ink)]">${it.t}</span>
              <span class="block truncate text-sm text-[var(--color-muted)]">${it.s}</span>
            </span>
          </a>`;
          results.appendChild(li);
        }
      }

      function search(query) {
        const n = query.trim().toLowerCase();
        if (!n) return render(data, '');
        const hits = data.filter((it) => {
          const hay = (it.t + ' ' + it.s + ' ' + (it.a || []).join(' ')).toLowerCase();
          return n.split(/\s+/).every((tok) => hay.includes(tok));
        });
        render(hits, query);
      }

      q.addEventListener('input', (e) => search(e.target.value));
      const initial = new URLSearchParams(location.search).get('q') || '';
      if (initial) q.value = initial;
      search(initial);
    })();
  </script>
</BaseLayout>
