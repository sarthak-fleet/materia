---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import EvidenceBadge from '@/components/astro/EvidenceBadge.astro';
import { getCompoundView } from '@/lib/graph';

export async function getStaticPaths() {
  const compounds = await getCollection('compounds');
  return compounds.map((c) => ({ params: { slug: c.id }, props: { compound: c } }));
}

const { compound } = Astro.props;
const remedies = await getCompoundView(compound.id);
const { Content } = await render(compound);
---

<BaseLayout title={compound.data.name} description={compound.data.summary}>
  <article class="container-x py-12">
    <p class="eyebrow mb-3">Active compound</p>
    <h1 class="text-4xl">{compound.data.name}</h1>
    {
      compound.data.classification && (
        <p class="mt-1 text-sm text-faint">{compound.data.classification}</p>
      )
    }
    <p class="prose-materia mt-4 text-lg text-muted">{compound.data.summary}</p>

    {
      compound.data.mechanism && (
        <div class="card mt-6 max-w-2xl p-5">
          <h2 class="eyebrow mb-2">Mechanism</h2>
          <p class="text-sm text-fg">{compound.data.mechanism}</p>
          {compound.data.targets.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {compound.data.targets.map((t) => (
                <span class="rounded-md border border-line bg-surface-2 px-2 py-0.5 text-[12.5px] text-muted">
                  {t}
                </span>
              ))}
            </div>
          )}
        </div>
      )
    }

    <section class="mt-10">
      <h2 class="font-display text-2xl text-ink">Found in</h2>
      <p class="mt-1 text-sm text-muted">Remedies that contain {compound.data.name}.</p>
      {
        remedies.length === 0 ? (
          <p class="mt-3 text-sm text-faint">No remedies linked yet.</p>
        ) : (
          <ul class="mt-5 space-y-2">
            {remedies.map(({ remedy, bestGrade }) => (
              <li class="card flex items-center justify-between gap-4 p-4 hover:border-line-strong">
                <a href={`/remedy/${remedy.id}`} class="font-medium text-ink hover:text-accent">
                  {remedy.data.name}
                  <span class="ml-2 text-[12px] font-normal text-faint">{remedy.data.kind}</span>
                </a>
                {bestGrade && <EvidenceBadge grade={bestGrade} size="sm" showLabel />}
              </li>
            ))}
          </ul>
        )
      }
    </section>

    {
      compound.body && compound.body.trim().length > 0 && (
        <section class="prose-materia mt-12 text-fg">
          <Content />
        </section>
      )
    }
  </article>
</BaseLayout>
