---
import { getCollection, getEntries, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SYSTEM_BY_ID } from '@/data/systems';

export async function getStaticPaths() {
  const parts = await getCollection('bodyParts');
  return parts.map((p) => ({ params: { slug: p.id }, props: { part: p } }));
}

const { part } = Astro.props;
const conditions = part.data.conditions.length ? await getEntries(part.data.conditions) : [];
const { Content } = await render(part);
---

<BaseLayout title={part.data.name} description={part.data.summary}>
  <article class="container-x py-12">
    <p class="eyebrow mb-3">Body part</p>
    <h1 class="text-4xl">{part.data.name}</h1>
    <div class="mt-3 flex flex-wrap gap-2">
      {
        part.data.systems.map((s) => (
          <span class="rounded-full bg-surface-2 px-3 py-1 text-xs text-muted">
            {SYSTEM_BY_ID[s].name}
          </span>
        ))
      }
    </div>
    <p class="prose-materia mt-4 text-lg text-muted">{part.data.summary}</p>

    <section class="mt-10">
      <h2 class="font-display text-2xl text-ink">Common conditions</h2>
      {
        conditions.length === 0 ? (
          <p class="mt-3 text-sm text-faint">No conditions linked yet.</p>
        ) : (
          <ul class="mt-5 grid gap-3 sm:grid-cols-2">
            {conditions.map((c) => (
              <li>
                <a
                  href={`/condition/${c.id}`}
                  class="card block h-full p-4 transition-colors hover:border-accent hover:bg-accent-soft"
                >
                  <p class="font-medium text-ink">{c.data.name}</p>
                  <p class="mt-1 text-sm text-muted">{c.data.summary}</p>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </section>

    {
      part.body && part.body.trim().length > 0 && (
        <section class="prose-materia mt-12 text-fg">
          <Content />
        </section>
      )
    }
  </article>
</BaseLayout>
