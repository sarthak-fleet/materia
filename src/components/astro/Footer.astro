---
import { site } from '@/data/site';

const year = new Date().getFullYear();
const cols = [
  {
    title: 'Explore',
    links: [
      { label: 'Body explorer', href: '/' },
      { label: 'Conditions', href: '/conditions' },
      { label: 'Remedies', href: '/remedies' },
      { label: 'Compounds', href: '/compounds' },
    ],
  },
  {
    title: 'About',
    links: [
      { label: 'Methodology', href: '/methodology' },
      { label: 'About Materia', href: '/about' },
      { label: 'Disclaimer', href: '/disclaimer' },
    ],
  },
];
---

<footer class="mt-24 border-t border-line bg-surface-2/40">
  <div class="container-x grid gap-10 py-12 sm:grid-cols-[1.5fr_1fr_1fr]">
    <div class="max-w-xs">
      <div class="flex items-center gap-2">
        <span
          class="grid h-6 w-6 place-items-center rounded bg-accent text-[13px] font-semibold text-white"
          style="font-family: var(--font-display)">M</span
        >
        <span class="font-medium text-ink" style="font-family: var(--font-display)">Materia</span>
      </div>
      <p class="mt-3 text-sm text-muted">{site.tagline}</p>
      <p class="mt-3 text-[12.5px] leading-relaxed text-faint">
        Ad-free. We don’t sell supplements. Every claim is graded and cited.
      </p>
    </div>
    {
      cols.map((col) => (
        <div>
          <h4 class="eyebrow mb-3">{col.title}</h4>
          <ul class="space-y-2">
            {col.links.map((l) => (
              <li>
                <a href={l.href} class="text-sm text-muted transition-colors hover:text-ink">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
  <div class="border-t border-line">
    <p class="container-x py-4 text-[12px] text-faint">
      © {year} {site.name}. Educational reference only — not medical advice.
    </p>
  </div>
</footer>
