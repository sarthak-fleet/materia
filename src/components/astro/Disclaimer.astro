---
import { DISCLAIMER_SHORT } from '@/data/site';

interface Props {
  /** `banner` = slim site-wide strip; `block` = inline notice on entity pages. */
  variant?: 'banner' | 'block';
}
const { variant = 'banner' } = Astro.props;
---

{
  variant === 'banner' ? (
    <div class="border-b border-line bg-surface-2/60">
      <p class="container-x py-1.5 text-center text-[12.5px] text-muted">
        {DISCLAIMER_SHORT} <a href="/disclaimer" class="link-accent">Read more</a>.
      </p>
    </div>
  ) : (
    <aside class="card flex gap-3 border-caution/30 bg-caution-soft/50 p-4 text-sm text-fg">
      <svg
        class="mt-0.5 shrink-0 text-caution"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="m21.7 18-8-14a2 2 0 0 0-3.4 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.7-3Z" />
        <path d="M12 9v4" />
        <path d="M12 17h.01" />
      </svg>
      <p>
        <strong class="font-medium text-ink">This is educational information, not medical advice.</strong>{' '}
        {DISCLAIMER_SHORT} Evidence is summarized from cited research and may be incomplete or
        change. See our <a href="/methodology" class="link-accent">methodology</a>.
      </p>
    </aside>
  )
}
