---
interface Props {
  typicalUse?: { form?: string; studiedRange?: string; notes?: string };
}
const { typicalUse } = Astro.props;
const { form, studiedRange, notes } = typicalUse ?? {};
const rows = [
  { label: 'Form studied', value: form },
  { label: 'Amounts in trials', value: studiedRange },
  { label: 'Notes', value: notes },
].filter((r) => r.value);
---

{
  rows.length > 0 && (
    <div class="card p-5">
      <h3 class="font-display text-lg text-ink">What researchers studied</h3>
      <p class="mt-1 text-[12.5px] text-faint">
        These describe how the remedy was used in studies — not a dose or a recommendation.
      </p>
      <dl class="mt-3 space-y-2">
        {rows.map((r) => (
          <div class="flex gap-3 text-sm">
            <dt class="w-32 shrink-0 text-muted">{r.label}</dt>
            <dd class="text-fg">{r.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  )
}
