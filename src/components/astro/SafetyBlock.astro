---
interface Safety {
  interactions: string[];
  contraindications: string[];
  sideEffects: string[];
  pregnancy: 'avoid' | 'caution' | 'likely-safe' | 'unknown';
}
interface Props {
  safety: Safety;
}
const { safety } = Astro.props;

const pregLabel: Record<Safety['pregnancy'], { text: string; color: string }> = {
  avoid: { text: 'Avoid in pregnancy', color: 'var(--color-warn)' },
  caution: { text: 'Caution in pregnancy', color: 'var(--color-caution)' },
  'likely-safe': { text: 'Likely safe in pregnancy', color: 'var(--color-grade-a)' },
  unknown: { text: 'Pregnancy safety unknown', color: 'var(--color-grade-none)' },
};
const preg = pregLabel[safety.pregnancy];

const rows = [
  { label: 'Interactions', items: safety.interactions },
  { label: 'Contraindications', items: safety.contraindications },
  { label: 'Side effects', items: safety.sideEffects },
];
const hasAny = rows.some((r) => r.items.length > 0);
---

<div class="card p-5">
  <h3 class="font-display text-lg text-ink">Safety</h3>
  <div class="mt-3 flex items-center gap-2">
    <span class="h-2 w-2 rounded-full" style={`background:${preg.color}`}></span>
    <span class="text-sm text-fg">{preg.text}</span>
  </div>

  {
    hasAny ? (
      <dl class="mt-4 space-y-3">
        {rows
          .filter((r) => r.items.length > 0)
          .map((r) => (
            <div>
              <dt class="eyebrow mb-1">{r.label}</dt>
              <dd>
                <ul class="flex flex-wrap gap-1.5">
                  {r.items.map((it) => (
                    <li class="rounded-md border border-line bg-surface-2 px-2 py-0.5 text-[12.5px] text-fg">
                      {it}
                    </li>
                  ))}
                </ul>
              </dd>
            </div>
          ))}
      </dl>
    ) : (
      <p class="mt-3 text-sm text-faint">No interactions or contraindications recorded yet.</p>
    )
  }
  <p class="mt-4 border-t border-line pt-3 text-[12px] text-faint">
    Safety data is not exhaustive. Always check with a clinician or pharmacist before combining
    remedies or medications.
  </p>
</div>
